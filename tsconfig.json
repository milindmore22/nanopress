{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"allowJs": false,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "preserve",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "webpack.config.js"],
	"exclude": ["build", "node_modules", "vendor"]
}
